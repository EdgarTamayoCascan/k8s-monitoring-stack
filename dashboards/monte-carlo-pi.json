{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Monte Carlo estimation of Pi by throwing random darts at a unit circle inscribed in a 2×2 square. Watch the estimate converge to π ≈ 3.14159 over time.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "🎯 Monte Carlo Pi Estimation",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "π Estimate",
      "description": "Current Monte Carlo estimate of Pi (should converge to 3.14159...)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "decimals": 6,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 3.0 },
              { "color": "yellow", "value": 3.1 },
              { "color": "green", "value": 3.14 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "avg(monte_carlo_pi_estimate)",
          "legendFormat": "π estimate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Absolute Error",
      "description": "|estimate - π|",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "decimals": 6,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "avg(monte_carlo_error)",
          "legendFormat": "error",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Throws",
      "description": "Number of darts thrown across all pods",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(monte_carlo_throws_total)",
          "legendFormat": "throws",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Throws/sec",
      "description": "Rate of darts being thrown",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "light-blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(rate(monte_carlo_throws_total[1m]))",
          "legendFormat": "throws/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Convergence & Error",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false
    },
    {
      "title": "π Convergence Over Time",
      "description": "Watch the Monte Carlo estimate (orange line) converge toward true π (dashed blue line) as more darts are thrown",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "decimals": 5,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 0,
            "pointSize": 3,
            "showPoints": "never",
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "true π" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "avg(monte_carlo_pi_estimate)",
          "legendFormat": "π estimate",
          "refId": "A"
        },
        {
          "expr": "vector(3.14159265358979)",
          "legendFormat": "true π",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Hits vs Misses",
      "description": "Cumulative count of darts inside (hit) and outside (miss) the circle. Hit rate should converge to π/4 ≈ 78.54%.",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "hits (inside circle)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "misses (outside circle)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom", "values": ["value", "percent"] }
      },
      "targets": [
        {
          "expr": "sum(monte_carlo_hits_total)",
          "legendFormat": "hits (inside circle)",
          "refId": "A"
        },
        {
          "expr": "sum(monte_carlo_throws_total) - sum(monte_carlo_hits_total)",
          "legendFormat": "misses (outside circle)",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Absolute Error |estimate − π| Over Time",
      "description": "The error should shrink as more darts are thrown — this is the Monte Carlo convergence in action",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "decimals": 6,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "pointSize": 3,
            "showPoints": "never",
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "avg(monte_carlo_error)",
          "legendFormat": "|estimate − π|",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Per-Pod π Estimate",
      "description": "Compare estimates from each replica — they should converge independently toward true π (dashed line)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "decimals": 5,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 0,
            "pointSize": 3,
            "showPoints": "never",
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "true π" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "monte_carlo_pi_estimate",
          "legendFormat": "{{kubernetes_pod_name}}",
          "refId": "A"
        },
        {
          "expr": "vector(3.14159265358979)",
          "legendFormat": "true π",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Logs",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false
    },
    {
      "title": "Recent Dart Throws (Loki)",
      "description": "Live log stream of individual dart throws from the Monte Carlo simulator",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 25 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{k8s_namespace_name=\"monitoring\", service_name=\"simulator\"} | json",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["monte-carlo", "pi", "simulation", "kubernetes"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      },
      {
        "current": {},
        "hide": 2,
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Monte Carlo Pi Estimation",
  "uid": "monte-carlo-pi",
  "version": 1
}
